-- en/01-submit-missing-json/argv --
crater order submit --json --no-interactive
-- en/01-submit-missing-json/exit --
2
-- en/01-submit-missing-json/stdout --
-- en/01-submit-missing-json/stderr --
{
  "category": "usage_error",
  "code": "ERR_MISSING_REQUIRED_FLAG",
  "message": "order name is required (--name)\napproval reason is required (--reason)",
  "context": {
    "issues": [
      {
        "code": "ERR_MISSING_REQUIRED_FLAG",
        "field": "name",
        "message": "order name is required (--name)"
      },
      {
        "code": "ERR_MISSING_REQUIRED_FLAG",
        "field": "reason",
        "message": "approval reason is required (--reason)"
      }
    ]
  }
}
