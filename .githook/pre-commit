#!/bin/sh

# Unified pre-commit hook that delegates checks to sub-projects
# Only checks sub-projects with changed files

# Ensure we're in the repository root directory
# Git hooks are executed from the repository root, but we verify this
if [ ! -d ".git" ] && [ ! -f ".git" ]; then
    # Try to find .git directory by going up
    GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
    if [ -n "$GIT_ROOT" ]; then
        cd "$GIT_ROOT" || exit 1
    fi
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

# If no staged files, check if there are modified files
if [ -z "$STAGED_FILES" ]; then
    # Check if there are any modified files (not staged)
    MODIFIED_FILES=$(git diff --name-only 2>/dev/null)
    if [ -n "$MODIFIED_FILES" ]; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "⚠️  Warning: No staged files found, but there are modified files"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "Please stage your files first using 'git add' before committing."
        echo ""
        echo "Modified files:"
        echo "$MODIFIED_FILES" | sed 's/^/  - /'
        echo ""
        echo "💡 Tip: You can also run checks directly in sub-project directories:"
        echo "   cd frontend && make pre-commit-check"
        echo "   cd backend && make pre-commit-check"
        echo "   cd website && make pre-commit-check"
        echo ""
        exit 0
    fi
    # No staged files and no modified files, exit successfully
    exit 0
fi

# Track if any checks were run
CHECKS_RUN=0

# Check if there are website-related changes
if echo "$STAGED_FILES" | grep -q "^website/"; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🌐 Website Checks"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if (cd website && make pre-commit-check); then
        echo "✅ Website checks passed!"
        CHECKS_RUN=1
    else
        echo "❌ Website checks failed!"
        exit 1
    fi
fi

# Check if there are frontend-related changes
if echo "$STAGED_FILES" | grep -q "^frontend/"; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🎨 Frontend Checks"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if (cd frontend && make pre-commit-check); then
        echo "✅ Frontend checks passed!"
        CHECKS_RUN=1
    else
        echo "❌ Frontend checks failed!"
        exit 1
    fi
fi

# Check if there are backend-related changes
if echo "$STAGED_FILES" | grep -q "^backend/"; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🔧 Backend Checks"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if (cd backend && make pre-commit-check); then
        echo "✅ Backend checks passed!"
        CHECKS_RUN=1
    else
        echo "❌ Backend checks failed!"
        exit 1
    fi
fi

# Output final summary if any checks were run
if [ $CHECKS_RUN -eq 1 ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "✅ All checks passed!"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
else
    # No checks were run, but there are staged files
    # This means staged files are not in any monitored sub-project directory
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "✅ No checks to run"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
fi

exit 0
