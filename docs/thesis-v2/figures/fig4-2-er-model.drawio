<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="图 4-2 后端数据持久化 ER 模型（agent_* 七张核心表）" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="600" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="sessions" value="agent_sessions&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;user_id (fk → users)&#10;account_id (fk → accounts)&#10;title · source&#10;orchestration · status&#10;created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="60" y="80" width="220" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="turns" value="agent_turns&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;session_id (fk)&#10;turn_id · user_message&#10;final_answer · page_context&#10;continuation (jsonb)&#10;workflow (jsonb · ckpt v5)&#10;usage_summary · status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="340" y="80" width="240" height="180" as="geometry"/>
    </mxCell>
    <mxCell id="messages" value="agent_messages&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;turn_id (fk)&#10;role · content&#10;tool_calls (jsonb)&#10;agent_role" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="640" y="80" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="audit" value="agent_audit【核心审计表】&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;session_id · turn_id&#10;actor_id · actor_role&#10;tool_name · tool_args (jsonb)&#10;result (jsonb) · error&#10;latency_ms · risk_level&#10;permission · confirmation_id&#10;tool_call_id · agent_id&#10;created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="340" y="290" width="240" height="220" as="geometry"/>
    </mxCell>
    <mxCell id="confirm" value="agent_confirmations&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;session_id · turn_id&#10;action_id · tool_name&#10;action_payload (jsonb)&#10;checkpoint (jsonb)&#10;risk_level · status&#10;confirmed_by · confirmed_at&#10;reject_reason · expires_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="60" y="290" width="240" height="220" as="geometry"/>
    </mxCell>
    <mxCell id="inspect" value="agent_inspection_runs&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;scope · cron_expression&#10;triggered_by · target_count&#10;summary (jsonb) · report_url&#10;tokens_used · status&#10;started_at · finished_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="640" y="290" width="220" height="180" as="geometry"/>
    </mxCell>
    <mxCell id="quality" value="agent_quality_eval&#10;━━━━━━━━━━━━━&#10;id (uuid, pk)&#10;session_id · turn_id · user_id&#10;eval_type&#10;chat_judge_score&#10;chain_judge_score&#10;tool_f1 · root_cause_hit&#10;permission_compliance&#10;user_feedback (👍/👎)&#10;model_used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="900" y="290" width="220" height="220" as="geometry"/>
    </mxCell>
    <mxCell id="users" value="users（原平台表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontStyle=2;dashed=1" vertex="1" parent="1">
      <mxGeometry x="900" y="80" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="jobs" value="jobs / accounts / alerts（原平台表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontStyle=2;dashed=1" vertex="1" parent="1">
      <mxGeometry x="900" y="140" width="220" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="r1" value="1..N" style="endArrow=classic;html=1;startArrow=ERone;startSize=10;endSize=10;strokeColor=#444" edge="1" parent="1" source="sessions" target="turns"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="1..N" style="endArrow=classic;html=1;startArrow=ERone;startSize=10;endSize=10;strokeColor=#444" edge="1" parent="1" source="turns" target="messages"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r3" value="1..N" style="endArrow=classic;html=1;startArrow=ERone;startSize=10;endSize=10;strokeColor=#444;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="turns" target="audit"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r4" value="1..N" style="endArrow=classic;html=1;startArrow=ERone;startSize=10;endSize=10;strokeColor=#444;exitX=0;exitY=1;entryX=1;entryY=0.3" edge="1" parent="1" source="turns" target="confirm"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r5" value="0..1" style="endArrow=classic;html=1;startArrow=ERone;startSize=10;endSize=10;strokeColor=#999;dashed=1" edge="1" parent="1" source="confirm" target="audit"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r6" value="0..1" style="endArrow=classic;html=1;startArrow=ERone;startSize=10;endSize=10;strokeColor=#999;dashed=1" edge="1" parent="1" source="turns" target="quality"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r7" value="N..1" style="endArrow=classic;html=1;endArrow=ERone;startArrow=classic;startSize=10;endSize=10;strokeColor=#999;dashed=1" edge="1" parent="1" source="sessions" target="users"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="idx" value="关键索引：&#10;agent_audit (session_id, turn_id)、(actor_id, created_at DESC)、(tool_name, created_at) WHERE error&#10;agent_confirmations (status, expires_at) WHERE status=&#39;pending&#39;&#10;agent_inspection_runs (scope, started_at DESC)&#10;JSONB GIN：agent_audit.tool_args（支撑'上周哪些工具失败率最高'查询）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;fontStyle=2;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
      <mxGeometry x="60" y="540" width="1060" height="90" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
