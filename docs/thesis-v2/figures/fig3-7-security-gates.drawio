<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="图 3-7 安全四闸门：权限 → 确认 → 续接 → 审计" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="600" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="user" value="用户输入&#10;自然语言运维问题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="40" y="280" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="g1" value="① 权限过滤&#10;角色 → 工具白名单&#10;LLM 注入前完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="220" y="270" width="150" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="g2" value="② 操作确认&#10;medium/high 风险&#10;用户显式 Y/N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="400" y="270" width="150" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="g3" value="③ 确认续接&#10;workflow checkpoint&#10;无状态恢复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="580" y="270" width="150" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="g4" value="④ 审计追踪&#10;全链路日志&#10;persist + replay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="760" y="270" width="150" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="platform" value="平台 API&#10;K8s / Prometheus / DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;fontColor=#ffffff;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="940" y="280" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="user" target="g1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="g1" target="g2"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="g2" target="g3"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="g3" target="g4"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="g4" target="platform"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="d1" value="原则：禁止 LLM 输出&#10;覆盖角色字段" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#6c8ebf" vertex="1" parent="1">
      <mxGeometry x="200" y="370" width="190" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="d2" value="原则：暂停而非执行&#10;清晰展示影响" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#82b366" vertex="1" parent="1">
      <mxGeometry x="385" y="370" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="d3" value="原则：状态序列化&#10;Runtime 不持长链状态" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#d6b656" vertex="1" parent="1">
      <mxGeometry x="565" y="370" width="190" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="d4" value="原则：含被拒请求&#10;全部留痕可回放" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#b85450" vertex="1" parent="1">
      <mxGeometry x="745" y="370" width="190" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="reject" value="✘ 拒绝执行&#10;返回结构化错误" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontSize=10;dashed=1" vertex="1" parent="1">
      <mxGeometry x="220" y="430" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="reject2" value="✘ 用户拒绝&#10;计入 attempted_signatures" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontSize=10;dashed=1" vertex="1" parent="1">
      <mxGeometry x="400" y="430" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="reject3" value="✘ 超时未确认&#10;auto-expire" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontSize=10;dashed=1" vertex="1" parent="1">
      <mxGeometry x="580" y="430" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="re1" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450" edge="1" parent="1" source="g1" target="reject"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="re2" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450" edge="1" parent="1" source="g2" target="reject2"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="re3" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450" edge="1" parent="1" source="g3" target="reject3"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="audit_db" value="agent_audit&#10;agent_confirmations&#10;PostgreSQL 持久层" style="shape=cylinder3;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="780" y="430" width="120" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="a_edge" style="endArrow=classic;html=1;strokeColor=#b46504;dashed=1" edge="1" parent="1" source="g4" target="audit_db"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="invariant" value="安全不变量：任意时刻系统外部可见的风险等级不会高于初始基线（由 ①+② 联合保障，由 ④ 提供事后核查）" style="text;html=1;align=center;fontSize=11;fontStyle=2;fontColor=#444" vertex="1" parent="1">
      <mxGeometry x="60" y="540" width="1040" height="20" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
