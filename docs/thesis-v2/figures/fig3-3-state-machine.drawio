<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="图 3-3 协调器阶段状态机与回退分派" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="220" y="10" width="520" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="init" value="INIT" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="60" y="280" width="80" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="route" value="ROUTE&#10;意图路由" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1">
      <mxGeometry x="180" y="280" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="plan" value="PLAN&#10;规划" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="320" y="180" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="explore" value="EXPLORE&#10;探索" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="460" y="180" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="execute" value="EXECUTE&#10;执行" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="600" y="180" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="pause" value="PAUSE&#10;挂起" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12" vertex="1" parent="1">
      <mxGeometry x="620" y="80" width="80" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="resume" value="RESUME&#10;恢复" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12" vertex="1" parent="1">
      <mxGeometry x="740" y="80" width="80" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="verify" value="VERIFY&#10;验证" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="600" y="320" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="summary" value="SUMMARIZE&#10;汇总" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12" vertex="1" parent="1">
      <mxGeometry x="440" y="320" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;fontColor=#ffffff;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="320" y="325" width="80" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="endArrow=classic;html=1" edge="1" parent="1" source="init" target="route"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0;entryY=0.5" edge="1" parent="1" source="route" target="plan"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" style="endArrow=classic;html=1" edge="1" parent="1" source="plan" target="explore"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" style="endArrow=classic;html=1" edge="1" parent="1" source="explore" target="execute"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" value="awaiting_&#10;confirmation" style="endArrow=classic;html=1;fontSize=10;fontColor=#d79b00" edge="1" parent="1" source="execute" target="pause"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" style="endArrow=classic;html=1" edge="1" parent="1" source="pause" target="resume"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" value="checkpoint" style="endArrow=classic;html=1;fontSize=10;fontColor=#d79b00;exitX=0;exitY=1;entryX=1;entryY=0" edge="1" parent="1" source="resume" target="verify"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="execute" target="verify"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e9" value="pass" style="endArrow=classic;html=1;fontSize=10;fontColor=#82b366;fontStyle=1" edge="1" parent="1" source="verify" target="summary"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e10" style="endArrow=classic;html=1" edge="1" parent="1" source="summary" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="back1" value="missing_evidence&#10;→ 回退到 EXPLORE" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450;fontSize=10;fontColor=#b85450;exitX=0.5;exitY=0;entryX=0.5;entryY=1;curved=1" edge="1" parent="1" source="verify" target="explore"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="back2" value="risk → replan" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450;fontSize=10;fontColor=#b85450;exitX=0;exitY=0.5;entryX=0.5;entryY=1;curved=1" edge="1" parent="1" source="verify" target="plan"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="back3" value="retry → 重试动作" style="endArrow=classic;html=1;dashed=1;strokeColor=#b85450;fontSize=10;fontColor=#b85450;exitX=1;exitY=0.3;entryX=1;entryY=1;curved=1" edge="1" parent="1" source="verify" target="execute"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="guard" value="守护：lead_max_rounds=8 ｜ no_progress_count≥2 ｜ tool_signature 去重" style="text;html=1;align=center;fontSize=11;fontStyle=2;fontColor=#666" vertex="1" parent="1">
      <mxGeometry x="120" y="410" width="700" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="reassign" value="④ reassign：同一角色连续两轮无进展 → 切换模型 / 降级编排模式" style="text;html=1;align=center;fontSize=11;fontStyle=2;fontColor=#9673a6" vertex="1" parent="1">
      <mxGeometry x="120" y="435" width="700" height="20" as="geometry"/>
    </mxCell>
  </root>
