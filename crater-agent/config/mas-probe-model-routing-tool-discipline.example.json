{
  "scenariosDir": "../crater_bench/scenarios",
  "output": "../results/{timestamp}_mas-probe-model-routing-tool-discipline/offline-bench-summary.json",
  "report": "../results/{timestamp}_mas-probe-model-routing-tool-discipline/offline-bench-report.json",
  "parallel": 1,
  "repeat": 1,
  "repeatMetrics": "quality,tool,token,latency",
  "stopOnZeroLlm": true,
  "verbose": false,
  "mode": "snapshot",
  "orchestration": "multi",
  "suite": "mas-probe",
  "llm": {
    "roleClientMap": {
      "multi_agent.intent_router": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.coordinator": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.planner": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.explorer": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.executor": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.verifier": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.general": "qwen3.6-flash-2026-04-16-newkey",
      "multi_agent.guide": "qwen3.6-flash-2026-04-16-newkey"
    }
  },
  "benchmarkOverrides": {
    "multi_agent.planner": {
      "strategy": "recent",
      "systemPromptSuffix": "输出计划时优先保持步骤短、结构稳、不要过度规划。分布式 NCCL/RDMA 问题若已出现疑似节点，计划中同时包含 diagnose_distributed_job_network 和 get_node_network_summary；确认类写操作只做最小核验后进入确认流。"
    },
    "multi_agent.explorer": {
      "strategy": "compact",
      "systemPromptSuffix": "工具纪律：1) 分布式 NCCL/RDMA 或 allreduce timeout 场景，若 diagnose_distributed_job_network 返回 suspected_nodes 或用户追问某节点是否继续承接新作业，必须补一次 get_node_network_summary；2) 已有相同参数工具结果时禁止重复调用；3) 证据足够后直接总结。"
    },
    "multi_agent.executor": {
      "strategy": "last_turn_only",
      "systemPromptSuffix": "确认类写操作纪律：如果用户已明确要求 restart/stop/scale 等写操作且目标对象明确，只允许做一次必要只读核验，然后立即调用对应写工具进入 confirmation_required；不要重复 k8s_list_pods 或 k8s_get_events。"
    },
    "multi_agent.coordinator": {
      "strategy": "recent",
      "systemPromptSuffix": "协调纪律：确认类写操作目标明确时，不要让 Explorer 反复收集同类只读证据；分布式网络追问如果缺节点网络摘要，应继续 observe，否则 finalize。"
    }
  },
  "offlineEvaluation": {
    "multiTurnDialogueJudgeRoles": [
      "dialogue_eval_flash"
    ],
    "taskJudgeRoles": [
      "general_eval_flash"
    ],
    "confirmationTaskJudgeRoles": [
      "general_eval_flash"
    ],
    "difficultyWeights": {
      "easy": 1.0,
      "medium": 1.2,
      "hard": 1.5
    },
    "tokenBudgets": {
      "easy": 2500,
      "medium": 4500,
      "hard": 7000
    },
    "latencyBudgets": {
      "easy": 8000,
      "medium": 15000,
      "hard": 25000
    },
    "scoreWeights": {
      "tool_selection": 15,
      "root_cause": 15,
      "suggestion": 10,
      "safety": 10,
      "efficiency": 8,
      "token_efficiency": 7,
      "latency_efficiency": 2,
      "duplicate_control": 0,
      "completion_signal": 0,
      "dialogue_intent": 10,
      "dialogue_completeness": 5,
      "dialogue_satisfaction": 5,
      "task_chain_quality": 15
    },
    "missingSnapshotPolicy": "error"
  },
  "experiments": [
    {
      "name": "qwen36_flash_all_roles_tool_discipline_newkey",
      "description": "当前最低成本强基线：全部 MAS 角色使用 qwen3.6-flash-2026-04-16-newkey，并启用工具纪律 prompt。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1
    },
    {
      "name": "qwen36_max_core_tool_discipline_newkey",
      "description": "Coordinator/Executor/Verifier/General/Guide 升级到 qwen3.6-max-preview-newkey，Planner/Explorer/IntentRouter 保持 flash-newkey，验证强核心是否提升诊断与确认质量。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "llm": {
        "roleClientMap": {
          "multi_agent.coordinator": "qwen3.6-max-preview-newkey",
          "multi_agent.executor": "qwen3.6-max-preview-newkey",
          "multi_agent.verifier": "qwen3.6-max-preview-newkey",
          "multi_agent.general": "qwen3.6-max-preview-newkey",
          "multi_agent.guide": "qwen3.6-max-preview-newkey"
        }
      }
    },
    {
      "name": "deepseek_v4_core_tool_discipline_newkey",
      "description": "Coordinator/Executor/Verifier/General/Guide 使用 deepseek-v4-flash-newkey，测试非 Qwen 推理核心在运维工具调用和确认链路上的适配性。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "llm": {
        "roleClientMap": {
          "multi_agent.coordinator": "deepseek-v4-flash-newkey",
          "multi_agent.executor": "deepseek-v4-flash-newkey",
          "multi_agent.verifier": "deepseek-v4-flash-newkey",
          "multi_agent.general": "deepseek-v4-flash-newkey",
          "multi_agent.guide": "deepseek-v4-flash-newkey"
        }
      }
    },
    {
      "name": "kimi_k26_core_tool_discipline_newkey",
      "description": "Coordinator/Executor/Verifier/General/Guide 使用 kimi-k2.6-newkey，测试长上下文通用模型在证据整合和最终回答质量上的适配性。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "llm": {
        "roleClientMap": {
          "multi_agent.coordinator": "kimi-k2.6-newkey",
          "multi_agent.executor": "kimi-k2.6-newkey",
          "multi_agent.verifier": "kimi-k2.6-newkey",
          "multi_agent.general": "kimi-k2.6-newkey",
          "multi_agent.guide": "kimi-k2.6-newkey"
        }
      }
    }
  ]
}
