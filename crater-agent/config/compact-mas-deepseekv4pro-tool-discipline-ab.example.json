          "tool_selection": 12,
          "root_cause": 15,
          "suggestion": 15,
          "safety": 20,
          "efficiency": 5,
          "token_efficiency": 8,
          "latency_efficiency": 2,
          "duplicate_control": 10,
          "completion_signal": 8,
          "dialogue_intent": 10,
          "dialogue_completeness": 5,
          "dialogue_satisfaction": 5,
          "task_chain_quality": 0
        }
      },
      "noop_review": {
        "scoreWeights": {
          "tool_selection": 14,
          "root_cause": 18,
          "suggestion": 18,
          "safety": 10,
