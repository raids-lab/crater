    "missingSnapshotPolicy": "error"
  },
  "experiments": [
    {
      "name": "deepseekv4pro_compact_baseline",
      "description": "deepseek-v4-pro 全角色 compact-36 基线，保留相同 memory 策略，不加 tool-discipline prompt。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1
    },
    {
      "name": "deepseekv4pro_compact_tool_discipline",
      "description": "deepseek-v4-pro 全角色 compact-36，同配置仅增加 tool-discipline prompt。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "benchmarkOverrides": {
        "multi_agent.planner": {
          "systemPromptSuffix": "输出计划时优先保持步骤短、结构稳、不要过度规划。分布式 NCCL/RDMA 问题若已出现疑似节点，计划中同时包含 diagnose_distributed_job_network 和 get_node_network_summary。确认类写操作先列出仍未核实的关键字段或风险点，再安排一到两次直接相关的只读核验；不要把用户自述或页面状态当成已验证事实，也不要扩散到无关 read。"
        },
        "multi_agent.explorer": {
          "systemPromptSuffix": "工具纪律：1) 分布式 NCCL/RDMA 或 allreduce timeout 场景，若 diagnose_distributed_job_network 返回 suspected_nodes 或用户追问某节点是否继续承接新作业，必须补一次 get_node_network_summary；2) 已有相同参数工具结果时禁止重复调用；3) 证据足够后直接总结。"
        },
        "multi_agent.executor": {
          "systemPromptSuffix": "确认类写操作纪律：目标明确时，不是立刻进确认，而是先补齐与该动作直接相关的最小事实。不要把用户自述当作已验证证据；不要猜默认资源参数。对 uncordon/restart/scale 等管理员写操作，先做一次风险相关核验；对 create_jupyter_job/create_webide_job 等创建类写操作，优先核实模板默认值、配额、镜像是否匹配，只有关键信息齐全后才调用写工具进入 confirmation_required。不要做与当前操作无关的只读调用。"
        },
        "multi_agent.coordinator": {
          "systemPromptSuffix": "协调纪律：确认类写操作目标明确时，不要让 Explorer 反复收集同类只读证据；分布式网络追问如果缺节点网络摘要，应继续 observe，否则 finalize。"
        }
      }
    }
  ]
}
