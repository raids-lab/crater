{
  "scenariosDir": "../crater_bench/scenarios",
  "output": "../results/{timestamp}_compact-mas-deepseekv4pro-tool-discipline-ab/offline-bench-summary.json",
  "report": "../results/{timestamp}_compact-mas-deepseekv4pro-tool-discipline-ab/offline-bench-report.json",
  "parallel": 1,
  "repeat": 1,
  "repeatMetrics": "quality,tool,token,latency",
  "stopOnZeroLlm": true,
  "verbose": false,
  "mode": "snapshot",
  "orchestration": "multi",
  "suite": "compact",
  "llm": {
    "roleClientMap": {
      "multi_agent.intent_router": "deepseek-pro",
      "multi_agent.coordinator": "deepseek-pro",
      "multi_agent.planner": "deepseek-pro",
      "multi_agent.explorer": "deepseek-pro",
      "multi_agent.executor": "deepseek-pro",
      "multi_agent.verifier": "deepseek-pro",
      "multi_agent.general": "deepseek-pro",
      "multi_agent.guide": "deepseek-pro"
    }
  },
  "benchmarkOverrides": {
    "multi_agent.planner": {
      "strategy": "recent"
    },
    "multi_agent.explorer": {
      "strategy": "compact"
    },
    "multi_agent.executor": {
      "strategy": "last_turn_only"
    },
    "multi_agent.coordinator": {
      "strategy": "recent"
    }
  },
  "offlineEvaluation": {
    "multiTurnDialogueJudgeRoles": [
      "dialogue_eval_flash"
    ],
    "taskJudgeRoles": [
      "task_eval"
    ],
    "confirmationTaskJudgeRoles": [
      "task_eval"
    ],
    "difficultyWeights": {
      "easy": 1.0,
      "medium": 1.2,
      "hard": 1.5
    },
    "tokenBudgets": {
      "easy": 2500,
      "medium": 4500,
      "hard": 7000
    },
    "latencyBudgets": {
      "easy": 8000,
      "medium": 15000,
      "hard": 25000
    },
    "scoreWeights": {
      "tool_selection": 15,
      "root_cause": 15,
      "suggestion": 10,
      "safety": 10,
      "efficiency": 8,
      "token_efficiency": 7,
      "latency_efficiency": 2,
      "duplicate_control": 0,
      "completion_signal": 0,
      "dialogue_intent": 10,
      "dialogue_completeness": 5,
      "dialogue_satisfaction": 5,
      "task_chain_quality": 15
    },
    "scoreWeightProfiles": {
      "confirmation_flow": {
        "scoreWeights": {
          "tool_selection": 22,
