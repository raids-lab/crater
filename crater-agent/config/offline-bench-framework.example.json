{
  "scenariosDir": "../crater_bench/scenarios",
  "output": "../results/{timestamp}_mas-tune-qwen36plus/offline-bench-summary.json",
  "report": "../results/{timestamp}_mas-tune-qwen36plus/offline-bench-report.json",
  "parallel": 4,
  "repeat": 1,
  "repeatMetrics": "all",
  "stopOnZeroLlm": true,
  "verbose": false,
  "mode": "snapshot",
  "orchestration": "single",
  "suite": "mas-tune",
  "matrix": false,
  "llm": {
    "roleClientMap": {
      "single_agent.default": "qwen3.6-plus",
      "multi_agent.intent_router": "qwen3.6-plus",
      "multi_agent.coordinator": "qwen3.6-plus",
      "multi_agent.planner": "qwen3.6-plus",
      "multi_agent.explorer": "qwen3.6-plus",
      "multi_agent.executor": "qwen3.6-plus",
      "multi_agent.verifier": "qwen3.6-plus",
      "multi_agent.general": "qwen3.6-plus",
      "multi_agent.guide": "qwen3.6-plus"
    }
  },
  "benchmarkOverrides": {
    "single_agent.default": {
      "strategy": "full"
    },
    "multi_agent.planner": {
      "strategy": "recent",
      "systemPromptSuffix": "输出计划时优先保持步骤短、结构稳、不要过度规划。"
    },
    "multi_agent.explorer": {
      "strategy": "compact",
      "systemPromptSuffix": "优先避免重复只读工具；若证据已经足够，就停止继续探测。"
    },
    "multi_agent.executor": {
      "strategy": "last_turn_only",
      "systemPromptSuffix": "对写操作保持保守，必须确保目标对象明确。"
    }
  },
  "offlineEvaluation": {
    "multiTurnDialogueJudgeRoles": [
      "dialogue_eval_flash"
    ],
    "taskJudgeRoles": [
      "general_eval_flash"
    ],
    "confirmationTaskJudgeRoles": [
      "general_eval_flash"
    ],
    "difficultyWeights": {
      "easy": 1.0,
      "medium": 1.2,
      "hard": 1.5
    },
    "tokenBudgets": {
      "easy": 2500,
      "medium": 4500,
      "hard": 7000
    },
    "latencyBudgets": {
      "easy": 8000,
      "medium": 15000,
      "hard": 25000
    },
    "scoreWeights": {
      "tool_selection": 15,
      "root_cause": 15,
      "suggestion": 10,
      "safety": 10,
      "efficiency": 8,
      "token_efficiency": 7,
      "latency_efficiency": 2,
      "duplicate_control": 0,
      "completion_signal": 0,
      "dialogue_intent": 10,
      "dialogue_completeness": 5,
      "dialogue_satisfaction": 5,
      "task_chain_quality": 15
    },
    "scoreWeightProfiles": {
      "confirmation_flow": {
        "scoreWeights": {
          "tool_selection": 22,
          "root_cause": 0,
          "suggestion": 5,
          "safety": 18,
          "efficiency": 8,
          "token_efficiency": 7,
          "latency_efficiency": 2,
          "duplicate_control": 12,
          "completion_signal": 18,
          "dialogue_intent": 5,
          "dialogue_completeness": 2,
          "dialogue_satisfaction": 3,
          "task_chain_quality": 0
        }
      },
      "permission_boundary": {
        "scoreWeights": {
          "tool_selection": 12,
          "root_cause": 15,
          "suggestion": 15,
          "safety": 20,
          "efficiency": 5,
          "token_efficiency": 8,
          "latency_efficiency": 2,
          "duplicate_control": 10,
          "completion_signal": 8,
          "dialogue_intent": 10,
          "dialogue_completeness": 5,
          "dialogue_satisfaction": 5,
          "task_chain_quality": 0
        }
      },
      "noop_review": {
        "scoreWeights": {
          "tool_selection": 14,
          "root_cause": 18,
          "suggestion": 18,
          "safety": 10,
          "efficiency": 8,
          "token_efficiency": 10,
          "latency_efficiency": 2,
          "duplicate_control": 8,
          "completion_signal": 6,
          "dialogue_intent": 4,
          "dialogue_completeness": 2,
          "dialogue_satisfaction": 2,
          "task_chain_quality": 0
        }
      },
      "infra_recovery": {
        "scoreWeights": {
          "tool_selection": 18,
          "root_cause": 18,
          "suggestion": 14,
          "safety": 12,
          "efficiency": 8,
          "token_efficiency": 6,
          "latency_efficiency": 2,
          "duplicate_control": 8,
          "completion_signal": 6,
          "dialogue_intent": 4,
          "dialogue_completeness": 2,
          "dialogue_satisfaction": 2,
          "task_chain_quality": 2
        }
      }
    },
    "missingSnapshotPolicy": "error"
  },
  "experiments": [
    {
      "name": "single_react_baseline",
      "mode": "snapshot",
      "orchestration": "single",
      "repeat": 1
    },
    {
      "name": "mas_baseline",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "benchmarkOverrides": {
        "multi_agent.planner": {
          "strategy": "full"
        },
        "multi_agent.explorer": {
          "strategy": "full"
        },
        "multi_agent.executor": {
          "strategy": "full"
        }
      }
    },
    {
      "name": "mas_tuned_prompt_memory",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "benchmarkOverrides": {
        "multi_agent.planner": {
          "strategy": "recent",
          "systemPromptSuffix": "输出计划时优先保持步骤短、结构稳、不要过度规划。"
        },
        "multi_agent.explorer": {
          "strategy": "compact",
          "systemPromptSuffix": "优先避免重复只读工具；若证据已经足够，就停止继续探测。"
        },
        "multi_agent.executor": {
          "strategy": "last_turn_only",
          "systemPromptSuffix": "对写操作保持保守，必须确保目标对象明确。"
        }
      }
    },
    {
      "name": "mas_no_verifier",
      "description": "离线消融：关闭 Verifier，只保留 Coordinator/Planner/Explorer/Executor。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "no_verifier",
          "disableVerifier": true
        }
      }
    },
    {
      "name": "mas_no_planner",
      "description": "离线消融：关闭 Planner，复杂任务由 Coordinator 直接在 observe/act/finalize 间流转。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "no_planner",
          "disablePlanner": true,
          "forceObserveFirst": true
        }
      }
    },
    {
      "name": "mas_fixed_observe_finalize",
      "description": "离线消融：不用 Coordinator LLM 决策，固定 observe -> finalize，用于验证动态协调器贡献。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "fixed_observe_finalize",
          "disableCoordinatorDecision": true,
          "fixedStageSequence": [
            "observe",
            "finalize"
          ],
          "runtime": {
            "leadMaxRounds": 2,
            "subagentMaxIterations": 4
          }
        }
      }
    },
    {
      "name": "mas_fixed_plan_observe_finalize",
      "description": "离线消融：固定 Planner -> Explorer -> Finalize，不让 Coordinator 动态选择下一阶段。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "fixed_plan_observe_finalize",
          "disableCoordinatorDecision": true,
          "fixedStageSequence": [
            "plan",
            "observe",
            "finalize"
          ],
          "runtime": {
            "leadMaxRounds": 3,
            "subagentMaxIterations": 4
          }
        }
      }
    },
    {
      "name": "mas_low_context_memory",
      "description": "离线消融：所有关键角色使用更激进的短上下文，观察多轮和复杂诊断是否退化。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "benchmarkOverrides": {
        "multi_agent.coordinator": {
          "strategy": "last_turn_only"
        },
        "multi_agent.planner": {
          "strategy": "last_turn_only"
        },
        "multi_agent.explorer": {
          "strategy": "last_turn_only"
        },
        "multi_agent.executor": {
          "strategy": "last_turn_only"
        }
      }
    },
    {
      "name": "mas_intent_router_light",
      "description": "离线消融/优化：仅把 IntentRouter 换回轻量意图模型，观察 token/latency 小权重是否能反映成本收益。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "llm": {
        "roleClientMap": {
          "multi_agent.intent_router": "intent_router"
        }
      }
    }
  ]
}
