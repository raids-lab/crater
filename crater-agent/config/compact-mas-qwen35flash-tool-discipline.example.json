{
  "scenariosDir": "../crater_bench/scenarios",
  "output": "../results/{timestamp}_compact-mas-qwen35flash-tool-discipline/offline-bench-summary.json",
  "report": "../results/{timestamp}_compact-mas-qwen35flash-tool-discipline/offline-bench-report.json",
  "parallel": 1,
  "repeat": 1,
  "repeatMetrics": "quality,tool,token,latency",
  "stopOnZeroLlm": true,
  "verbose": false,
  "mode": "snapshot",
  "orchestration": "multi",
  "suite": "compact",
  "llm": {
    "roleClientMap": {
      "multi_agent.intent_router": "qwen3.5-flash",
      "multi_agent.coordinator": "qwen3.5-flash",
      "multi_agent.planner": "qwen3.5-flash",
      "multi_agent.explorer": "qwen3.5-flash",
      "multi_agent.executor": "qwen3.5-flash",
      "multi_agent.verifier": "qwen3.5-flash",
      "multi_agent.general": "qwen3.5-flash",
      "multi_agent.guide": "qwen3.5-flash"
    }
  },
  "benchmarkOverrides": {
    "multi_agent.planner": {
      "strategy": "recent",
      "systemPromptSuffix": "输出计划时优先保持步骤短、结构稳、不要过度规划。分布式 NCCL/RDMA 问题若已出现疑似节点，计划中同时包含 diagnose_distributed_job_network 和 get_node_network_summary。确认类写操作先列出仍未核实的关键字段或风险点，再安排一到两次直接相关的只读核验；不要把用户自述或页面状态当成已验证事实，也不要扩散到无关 read。"
    },
    "multi_agent.explorer": {
      "strategy": "compact",
      "systemPromptSuffix": "工具纪律：1) 每次只读调用都必须对应一个未决字段或风险点，与当前动作无关的 read 不要调；2) 分布式 NCCL/RDMA 或 allreduce timeout 场景，若 diagnose_distributed_job_network 返回 suspected_nodes 或用户追问某节点是否继续承接新作业，必须补一次 get_node_network_summary；3) 对 uncordon/restart/scale 等管理员写操作，不要只信用户自述，至少补一条与风险直接相关的节点或工作负载证据；4) 对 create_jupyter_job/create_webide_job 等创建类写操作，先核实镜像、模板默认值、配额等关键信息，不要猜 CPU/内存/GPU 型号；5) 已有相同参数工具结果时禁止重复调用；证据足够后立即停止探索。"
    },
    "multi_agent.executor": {
      "strategy": "last_turn_only",
      "systemPromptSuffix": "确认类写操作纪律：目标明确时，不是立刻进确认，而是先补齐与该动作直接相关的最小事实。不要把用户自述当作已验证证据；不要猜默认资源参数。对 uncordon/restart/scale 等管理员写操作，先做一次风险相关核验；对 create_jupyter_job/create_webide_job 等创建类写操作，优先核实模板默认值、配额、镜像是否匹配，只有关键信息齐全后才调用写工具进入 confirmation_required。不要做与当前操作无关的只读调用。"
    },
    "multi_agent.coordinator": {
      "strategy": "recent",
      "systemPromptSuffix": "协调纪律：确认类写操作不要一上来就冲确认，也不要放任 Explorer 扩散读取；只允许补齐与当前动作直接相关的未决事实。分布式网络追问如果缺节点网络摘要，应继续 observe，否则 finalize。"
    }
  },
