{
  "scenariosDir": "../crater_bench/scenarios",
  "output": "../results/{timestamp}_mas-tune-qwen36plus/offline-bench-summary.json",
  "report": "../results/{timestamp}_mas-tune-qwen36plus/offline-bench-report.json",
  "parallel": 2,
  "repeat": 1,
  "repeatMetrics": "quality,tool,token,latency",
  "stopOnZeroLlm": true,
  "verbose": false,
  "mode": "snapshot",
  "orchestration": "multi",
  "suite": "mas-tune-lite",
  "llm": {
    "roleClientMap": {
      "multi_agent.intent_router": "qwen3.6-plus",
      "multi_agent.coordinator": "qwen3.6-plus",
      "multi_agent.planner": "qwen3.6-plus",
      "multi_agent.explorer": "qwen3.6-plus",
      "multi_agent.executor": "qwen3.6-plus",
      "multi_agent.verifier": "qwen3.6-plus",
      "multi_agent.general": "qwen3.6-plus",
      "multi_agent.guide": "qwen3.6-plus"
    }
  },
  "benchmarkOverrides": {
    "multi_agent.planner": {
      "strategy": "recent",
      "systemPromptSuffix": "输出计划时优先保持步骤短、结构稳、不要过度规划。"
    },
    "multi_agent.explorer": {
      "strategy": "compact",
      "systemPromptSuffix": "优先避免重复只读工具；若证据已经足够，就停止继续探测。"
    },
    "multi_agent.executor": {
      "strategy": "last_turn_only",
      "systemPromptSuffix": "对写操作保持保守，必须确保目标对象明确。"
    }
  },
  "offlineEvaluation": {
    "multiTurnDialogueJudgeRoles": [
      "dialogue_eval_flash"
    ],
    "taskJudgeRoles": [
      "task_eval"
    ],
    "confirmationTaskJudgeRoles": [
      "task_eval"
    ],
    "difficultyWeights": {
      "easy": 1.0,
      "medium": 1.2,
      "hard": 1.5
    },
    "tokenBudgets": {
      "easy": 2500,
      "medium": 4500,
      "hard": 7000
    },
    "latencyBudgets": {
      "easy": 8000,
      "medium": 15000,
      "hard": 25000
    },
    "scoreWeights": {
      "tool_selection": 15,
      "root_cause": 15,
      "suggestion": 10,
      "safety": 10,
      "efficiency": 8,
      "token_efficiency": 7,
      "latency_efficiency": 2,
      "duplicate_control": 0,
      "completion_signal": 0,
      "dialogue_intent": 10,
      "dialogue_completeness": 5,
      "dialogue_satisfaction": 5,
      "task_chain_quality": 15
    },
    "missingSnapshotPolicy": "error"
  },
  "experiments": [
    {
      "name": "mas_tuned_prompt_memory",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1
    },
    {
      "name": "mas_baseline_full_memory",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "benchmarkOverrides": {
        "multi_agent.planner": {
          "strategy": "full"
        },
        "multi_agent.explorer": {
          "strategy": "full"
        },
        "multi_agent.executor": {
          "strategy": "full"
        }
      }
    },
    {
      "name": "mas_intent_router_light",
      "description": "仅把 IntentRouter 换回轻量意图模型，观察 token/latency 小权重是否能反映成本收益。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "llm": {
        "roleClientMap": {
          "multi_agent.intent_router": "intent_router"
        }
      }
    },
    {
      "name": "mas_no_verifier",
      "description": "关闭 Verifier，验证终局复核对任务完成质量的贡献。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "no_verifier",
          "disableVerifier": true
        }
      }
    },
    {
      "name": "mas_no_planner",
      "description": "关闭 Planner，复杂任务由 Coordinator 直接 observe/act/finalize。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "no_planner",
          "disablePlanner": true,
          "forceObserveFirst": true
        }
      }
    },
    {
      "name": "mas_fixed_observe_finalize",
      "description": "不用 Coordinator LLM 决策，固定 observe -> finalize，验证动态协调器贡献。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1,
      "offlineEvaluation": {
        "ablation": {
          "enabled": true,
          "name": "fixed_observe_finalize",
          "disableCoordinatorDecision": true,
          "fixedStageSequence": [
            "observe",
            "finalize"
          ],
          "runtime": {
            "leadMaxRounds": 2,
            "subagentMaxIterations": 4
          }
        }
      }
    }
  ]
}
