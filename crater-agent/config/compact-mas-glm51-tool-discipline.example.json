    "missingSnapshotPolicy": "error"
  },
  "experiments": [
    {
      "name": "glm51_compact_tool_discipline",
      "description": "36 个 compact 场景上的 MAS 主实验：glm-5.1 + 已验证的 prompt/memory/tool-discipline 优化。",
      "mode": "snapshot",
      "orchestration": "multi",
      "repeat": 1
    }
  ]
}
