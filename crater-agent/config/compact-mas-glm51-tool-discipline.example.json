      },
      "infra_recovery": {
        "scoreWeights": {
          "tool_selection": 18,
          "root_cause": 18,
          "suggestion": 14,
          "safety": 12,
          "efficiency": 8,
          "token_efficiency": 6,
          "latency_efficiency": 2,
          "duplicate_control": 8,
          "completion_signal": 6,
          "dialogue_intent": 4,
          "dialogue_completeness": 2,
