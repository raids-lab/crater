          <mxGeometry x="900" y="495" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- 索引说明 -->
        <mxCell id="idxBox" value="主要索引设计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="320" height="290" as="geometry" />
        </mxCell>
        <mxCell id="idx" value="agent_sessions&#10;  · idx_user_id  (user_id, last_active_at desc)&#10;  · idx_status_active  (status, last_active_at)&#10;&#10;agent_turns&#10;  · idx_session  (session_id, started_at)&#10;  · idx_status_running  (status) WHERE status=&#39;running&#39;&#10;&#10;agent_audit  (查询热点)&#10;  · idx_session_turn  (session_id, turn_id)&#10;  · idx_actor_time  (actor_id, created_at desc)&#10;  · idx_tool_failures&#10;       (tool_name, created_at) WHERE error IS NOT NULL&#10;  · gin_args  (tool_args)  GIN&#10;&#10;agent_confirmations&#10;  · idx_pending  (status, expires_at) WHERE status=&#39;pending&#39;&#10;&#10;agent_inspection_runs&#10;  · idx_scope_time  (scope, started_at desc)" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="50" y="525" width="300" height="250" as="geometry" />
        </mxCell>

        <!-- 设计要点 -->
        <mxCell id="design" value="设计要点：① 6 张新表均使用 uuid 主键 + jsonb 大字段，避免与原 Crater 表强耦合；② agent_audit / agent_confirmations 与 agent_turns 是&quot;一对多&quot;关系而非&quot;一对一&quot;，单轮可能产生多次工具调用与多个确认；&#10;③ tool_args 与 result 使用 jsonb + GIN 索引支持运维分析；④ workflow 字段保留完整 MASState checkpoint v5，是续接与回放的基础；⑤ agent_quality_eval 既存线上反馈也存离线评测，与 agent_turns 一对多" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;strokeWidth=2;dashed=1;fontSize=11;fontStyle=2;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="1340" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
