<mxfile host="app.diagrams.net" modified="2026-05-11T00:00:00.000Z" agent="Mops-Thesis" version="22.0">
  <diagram name="ER 数据模型" id="fig4-3">
    <mxGraphModel dx="1422" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="图 4-3 Mops 数据持久化 ER 模型（PostgreSQL · 6 张新增表 + 与 Crater 原表关联）" style="text;html=1;align=center;fontSize=17;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="240" y="20" width="920" height="30" as="geometry" />
        </mxCell>

        <!-- Crater 原有表（虚线） -->
        <mxCell id="t_users" value="users（原 Crater 表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;dashed=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="t_users_f" value="🔑 id  (PK · uint)&#10;name  varchar(64)&#10;email  varchar(128)&#10;role  enum(user, admin)&#10;ldap_uid  varchar(64)&#10;created_at  timestamp" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="50" y="115" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="t_jobs" value="jobs（原 Crater 表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;dashed=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="240" height="180" as="geometry" />
        </mxCell>
        <mxCell id="t_jobs_f" value="🔑 id  (PK · uint)&#10;name  varchar(128)&#10;user_id  uint  → users.id&#10;status  enum(...)&#10;exit_code  int&#10;gpu_request  int&#10;started_at / ended_at" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="50" y="315" width="220" height="140" as="geometry" />
        </mxCell>

        <!-- agent_sessions -->
        <mxCell id="t_sess" value="agent_sessions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="370" y="80" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="t_sess_f" value="🔑 id            uuid (PK)&#10;user_id        uint → users.id&#10;account_id    uint&#10;title           varchar(256)&#10;source        enum(portal, admin, api)&#10;orchestration  jsonb&#10;created_at     timestamp&#10;last_active_at  timestamp&#10;status         enum(active, closed)" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="380" y="115" width="260" height="160" as="geometry" />
        </mxCell>

        <!-- agent_turns -->
        <mxCell id="t_turns" value="agent_turns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="370" y="310" width="280" height="240" as="geometry" />
        </mxCell>
        <mxCell id="t_turns_f" value="🔑 id              uuid (PK)&#10;session_id      uuid → sessions.id&#10;turn_id         varchar(64)&#10;user_message  text&#10;final_answer   text&#10;page_context  jsonb&#10;continuation   jsonb&#10;workflow       jsonb  (checkpoint v5)&#10;usage_summary jsonb&#10;status   enum(running, paused,&#10;              completed, failed)&#10;started_at  ended_at" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="380" y="345" width="260" height="200" as="geometry" />
        </mxCell>

        <!-- agent_messages -->
        <mxCell id="t_msg" value="agent_messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="370" y="580" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="t_msg_f" value="🔑 id          uuid (PK)&#10;turn_id      uuid → turns.id&#10;role  enum(user, assistant,&#10;            tool, system)&#10;content      text&#10;tool_calls   jsonb&#10;agent_role  varchar(32)&#10;created_at  timestamp" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="380" y="615" width="260" height="130" as="geometry" />
        </mxCell>

        <!-- agent_audit -->
        <mxCell id="t_audit" value="agent_audit&#10;（运维操作审计核心表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="740" y="80" width="320" height="290" as="geometry" />
        </mxCell>
        <mxCell id="t_audit_f" value="🔑 id              uuid (PK)&#10;session_id      uuid → sessions.id&#10;turn_id         uuid → turns.id&#10;actor_id        uint → users.id&#10;actor_role      varchar(16)&#10;tool_name      varchar(64)&#10;tool_args        jsonb&#10;result           jsonb&#10;error           text&#10;latency_ms     int&#10;risk_level      enum(low, med, high)&#10;permission     enum(read, write,&#10;                  admin_read, approve)&#10;confirmation_id  uuid?&#10;tool_call_id   varchar(64)&#10;agent_id       varchar(16)&#10;created_at     timestamp" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="750" y="115" width="300" height="250" as="geometry" />
        </mxCell>

        <!-- agent_confirmations -->
        <mxCell id="t_conf" value="agent_confirmations&#10;（高风险操作确认表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;strokeWidth=3;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="740" y="400" width="320" height="290" as="geometry" />
        </mxCell>
        <mxCell id="t_conf_f" value="🔑 id              uuid (PK)&#10;session_id      uuid → sessions.id&#10;turn_id         uuid → turns.id&#10;action_id      varchar(64)&#10;tool_name      varchar(64)&#10;action_payload  jsonb&#10;     (操作 / 影响 / 历史)&#10;checkpoint     jsonb (workflow v5)&#10;risk_level      enum(med, high)&#10;status  enum(pending, confirmed,&#10;              rejected, timeout)&#10;confirmed_by   uint → users.id&#10;confirmed_at  timestamp&#10;reject_reason  text&#10;expires_at     timestamp&#10;created_at     timestamp" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="750" y="435" width="300" height="250" as="geometry" />
        </mxCell>

        <!-- agent_inspection_runs -->
        <mxCell id="t_insp" value="agent_inspection_runs&#10;（定时巡检任务）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1100" y="80" width="280" height="290" as="geometry" />
        </mxCell>
        <mxCell id="t_insp_f" value="🔑 id              uuid (PK)&#10;scope  enum(failed_jobs,&#10;             idle_jupyter,&#10;             gpu_low_util,&#10;             quota_review)&#10;cron_expression  varchar(32)&#10;triggered_by  enum(cron, manual)&#10;triggered_by_id  uint?&#10;target_count   int&#10;summary        jsonb&#10;report_url      varchar(256)&#10;status  enum(running, completed,&#10;              failed)&#10;tokens_used   int&#10;started_at&#10;ended_at" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="1110" y="115" width="260" height="250" as="geometry" />
        </mxCell>

        <!-- agent_quality_eval -->
        <mxCell id="t_qe" value="agent_quality_eval&#10;（质量评分回流）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1100" y="400" width="280" height="290" as="geometry" />
        </mxCell>
        <mxCell id="t_qe_f" value="🔑 id          uuid (PK)&#10;session_id  uuid → sessions.id&#10;turn_id      uuid → turns.id&#10;user_id     uint → users.id&#10;eval_type   enum(feedback,&#10;            manual, automatic)&#10;chat_judge_score  float&#10;chain_judge_score  float&#10;tool_f1     float&#10;root_cause_hit  bool&#10;permission_compliance  bool&#10;user_feedback  enum(up, down)&#10;feedback_comment  text&#10;model_used     varchar(64)&#10;created_at      timestamp" style="text;html=1;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="1110" y="435" width="260" height="250" as="geometry" />
        </mxCell>

        <!-- Relationships -->
        <mxCell id="r1" style="endArrow=ERmany;startArrow=ERone;html=1;strokeColor=#666666;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="t_users" target="t_sess">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r1l" value="user 拥有 N 会话" style="text;html=1;fontSize=10;fontStyle=2" vertex="1" parent="1">
