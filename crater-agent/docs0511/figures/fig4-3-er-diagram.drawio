          <mxGeometry x="650" y="285" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="r3" style="endArrow=ERmany;startArrow=ERone;html=1;strokeColor=#666666;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="t_turns" target="t_msg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r3l" value="turn 含 N 消息" style="text;html=1;fontSize=10;fontStyle=2" vertex="1" parent="1">
