          <mxGeometry as="geometry">
            <Array as="points">
              <mxPoint x="900" y="370" />
              <mxPoint x="900" y="385" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="r6l" value="confirmation_id&#10;(可选关联)" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="905" y="370" width="100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r7" style="endArrow=ERmany;startArrow=ERone;html=1;strokeColor=#666666;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="t_users" target="t_audit">
          <mxGeometry as="geometry">
