<mxfile host="app.diagrams.net" modified="2026-05-11T00:00:00.000Z" agent="Mops-Thesis" version="22.0">
  <diagram name="安全控制四闸门" id="fig3-7">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="图 3-7 Mops 安全控制四闸门：权限过滤 → 操作确认 → 确认续接 → 审计追踪" style="text;html=1;align=center;fontSize=17;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="220" y="20" width="960" height="30" as="geometry" />
        </mxCell>

        <!-- User request -->
        <mxCell id="req" value="LLM 生成工具调用&#10;{tool_name, args}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Gate 1: Permission filter -->
        <mxCell id="g1" value="闸门 ① 权限过滤&#10;━━━━━━━━━&#10;tool_selector.sanitize&#10;_resolve_actor_role&#10;&#10;● 角色仅来自 JWT&#10;● 页面 scope 可收窄&#10;● is_actor_allowed_for_tool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="220" height="200" as="geometry" />
        </mxCell>

        <!-- Gate 2: Operation confirmation -->
        <mxCell id="g2" value="闸门 ② 操作确认&#10;━━━━━━━━━&#10;Executor 检测 confirm=true&#10;构造 confirmation_payload&#10;序列化 workflow checkpoint&#10;&#10;● 操作目标&#10;● 潜在影响&#10;● 历史案例（类似失败）&#10;● 风险等级" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="540" y="100" width="220" height="200" as="geometry" />
        </mxCell>

        <!-- Gate 3: Resume -->
        <mxCell id="g3" value="闸门 ③ 确认续接&#10;━━━━━━━━━&#10;apply_resume_outcome&#10;workflow checkpoint 反序列化&#10;&#10;● confirm_id 匹配&#10;● action.status 更新&#10;● attempted_tool_signatures 去重&#10;● Verifier 再次校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="800" y="100" width="220" height="200" as="geometry" />
        </mxCell>

        <!-- Gate 4: Audit -->
        <mxCell id="g4" value="闸门 ④ 审计追踪&#10;━━━━━━━━━&#10;PostgreSQL agent_audit&#10;持久化全链路&#10;&#10;● session_id, turn_id&#10;● actor, tool_name&#10;● args (JSONB), result&#10;● risk_level, confirmation_id&#10;● latency_ms, created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1060" y="100" width="220" height="200" as="geometry" />
        </mxCell>

        <!-- Final -->
        <mxCell id="final" value="工具实际执行&#10;Backend 调用 K8s/Prom" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#3d7e29;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="1320" y="450" width="60" height="120" as="geometry" />
        </mxCell>

        <!-- Edges between gates -->
        <mxCell id="er1" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="req" target="g1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="g1" target="g2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12l" value="permission OK" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="500" y="180" width="60" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e23" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="g2" target="g3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23l" value="用户批准" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#D79B00" vertex="1" parent="1">
          <mxGeometry x="760" y="180" width="60" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e34" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="g3" target="g4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Reject paths -->
        <mxCell id="reject1" value="✗ 拒绝&#10;结构化错误&#10;返回用户" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8E0DD;strokeColor=#b85450;fontSize=10;align=center" vertex="1" parent="1">
          <mxGeometry x="310" y="370" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reject2" value="✗ 拒绝&#10;Coordinator 收到&#10;action.rejected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8E0DD;strokeColor=#b85450;fontSize=10;align=center" vertex="1" parent="1">
          <mxGeometry x="570" y="370" width="140" height="70" as="geometry" />
        </mxCell>

        <mxCell id="er1r" style="endArrow=classic;html=1;strokeColor=#B85450;dashed=1" edge="1" parent="1" source="g1" target="reject1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er1rl" value="permission 不足" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="210" y="335" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="er2r" style="endArrow=classic;html=1;strokeColor=#B85450;dashed=1" edge="1" parent="1" source="g2" target="reject2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2rl" value="用户拒绝 / 超时" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="475" y="335" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Audit always written -->
        <mxCell id="auditAll" value="所有事件均写入审计（成功 / 拒绝 / 超时 / 错误）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=2;dashed=1;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="280" y="465" width="1000" height="35" as="geometry" />
        </mxCell>
        <mxCell id="aa1" style="endArrow=classic;html=1;strokeColor=#B85450;dashed=1" edge="1" parent="1" source="reject1" target="auditAll"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aa2" style="endArrow=classic;html=1;strokeColor=#B85450;dashed=1" edge="1" parent="1" source="reject2" target="auditAll"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aa4" style="endArrow=classic;html=1;strokeColor=#B85450;dashed=1" edge="1" parent="1" source="g4" target="auditAll"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="afFinal" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="g4" target="final"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Detailed gates -->
        <mxCell id="detTitle" value="各闸门关键实现要点" style="text;html=1;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="510" width="400" height="25" as="geometry" />
        </mxCell>

        <!-- Detail 1 -->
        <mxCell id="d1" value="闸门 ① 零信任三原则&#10;━━━━━━━━━━━&#10;1. 角色字段仅来自 Backend JWT，&#10;   忽略前端与 LLM 输出的 role 字段&#10;2. 页面 scope 可收窄权限&#10;   （admin → user）但不可放大&#10;3. 工具暴露给 LLM 前已过滤，&#10;   LLM 无法&quot;请求&quot;不可见工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="320" height="180" as="geometry" />
        </mxCell>

        <!-- Detail 2 -->
        <mxCell id="d2" value="闸门 ② 确认载荷构造&#10;━━━━━━━━━━━&#10;● action_summary：&#10;  &quot;将重启 jobX，3000 步训练将丢失&quot;&#10;● risk_level + risk_reason&#10;● historical_cases：&#10;  类似确认的历史结果分布&#10;● tool_args 完整展示给用户审阅&#10;● 批量操作支持逐项勾选" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="380" y="540" width="320" height="180" as="geometry" />
        </mxCell>

        <!-- Detail 3 -->
        <mxCell id="d3" value="闸门 ③ 续接的关键保证&#10;━━━━━━━━━━━&#10;● confirm_id 唯一匹配，避免错位&#10;● attempted_tool_signatures 防重放：&#10;  已确认的工具+参数指纹禁止再次提议&#10;● workflow v5 包含完整 MASState：&#10;  Goal/Plan/Obs/Exec/runtime_config&#10;● Runtime 在 PAUSE 期间不持有内存，&#10;  可水平扩展，可重启不丢任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="720" y="540" width="320" height="180" as="geometry" />
        </mxCell>

        <!-- Detail 4 -->
        <mxCell id="d4" value="闸门 ④ 审计可追溯性&#10;━━━━━━━━━━━&#10;● 落库使用 ring-buffer 异步批写&#10;  （512KB/turn），不阻塞 SSE&#10;● tool_args / result 使用 JSONB&#10;  + GIN 索引，支持运维分析查询&#10;● 完整 MASState 单独序列化&#10;  到 agent_turns.workflow 字段，&#10;  支持事后回放推理轨迹&#10;● 任何拒绝事件均记录原因" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1060" y="540" width="320" height="180" as="geometry" />
        </mxCell>

        <!-- Summary -->
        <mxCell id="summary" value="安全设计目标：(i) 任何写操作必经过 ②；(ii) 任何用户不可调用其无权工具（①），(iii) Runtime 无状态化（③ checkpoint 重建）；(iv) 全链路可回放（④ JSONB 持久化）。&#10;此设计借鉴 STRATUS 的 Transactional No-Regression 思想，并扩展到智算训练作业的不可逆操作（已释放的 GPU 卡时、已删除的 checkpoint 文件等）。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;fontStyle=2;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="740" width="1340" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
