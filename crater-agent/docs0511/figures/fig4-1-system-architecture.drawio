        <!-- 部署原则 -->
        <mxCell id="legend" value="部署关键约束：(i) Runtime 不持有 K8s 凭据，所有工具调用经 Backend 鉴权；(ii) Runtime 是无状态服务，HPA 弹性扩缩容；(iii) PostgreSQL 通过 StatefulSet 在同集群部署以减少跨集群延迟；&#10;(iv) Runtime 与 Backend 之间走 ClusterIP（不出集群）；(v) Runtime 与外部 LLM 服务走 Egress Gateway 统一鉴权与限流；(vi) 全部三服务由同一 Helm Chart 统一发布，避免独立部署引入运维割裂" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;fontStyle=2;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="810" width="1320" height="80" as="geometry" />
        </mxCell>

