<mxfile host="Electron" agent="Mops-Thesis">
  <diagram name="MASState 工件流转" id="fig3-3">
    <mxGraphModel dx="731" dy="632" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
