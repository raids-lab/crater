          <mxGeometry height="640" width="1320" x="40" y="70" as="geometry" />
        </mxCell>
        <mxCell id="secA" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;fontColor=#B85450" value="A. 四阶段工件（按时序填充）" vertex="1">
          <mxGeometry height="20" width="400" x="60" y="110" as="geometry" />
        </mxCell>
        <mxCell id="goal" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="GoalArtifact 目标工件&#xa;━━━━━━━━━━━&#xa;user_message: str&#xa;actor_role: &#39;user&#39; | &#39;admin&#39;&#xa;account_id: str&#xa;page_context:&#xa;  · route: str&#xa;  · job_name: str?&#xa;  · node_name: str?&#xa;  · pvc_name: str?&#xa;routing_decision:&#xa;  · entry_mode&#xa;  · operation_mode&#xa;  · complexity&#xa;━━━━━━━━━━━&#xa;✏ 写入：IntentRouter&#xa;👁 读取：全部角色" vertex="1">
          <mxGeometry height="320" width="290" x="60" y="140" as="geometry" />
        </mxCell>
        <mxCell id="plan" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="PlanArtifact 计划工件&#xa;━━━━━━━━━━━&#xa;steps[]:&#xa;  · step_id, description&#xa;  · expected_tool&#xa;  · pre_condition&#xa;candidate_tools[]: list[str]&#xa;risk_assessment:&#xa;  · low | medium | high&#xa;  · reasoning&#xa;stage_complete: bool&#xa;━━━━━━━━━━━&#xa;✏ 写入：Planner&#xa;👁 读取：Explorer, Executor, Verifier&#xa;🔄 回退入口：Verifier(replan)" vertex="1">
          <mxGeometry height="320" width="290" x="370" y="140" as="geometry" />
        </mxCell>
        <mxCell id="obs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="ObservationArtifact 观察工件&#xa;━━━━━━━━━━━&#xa;evidence[]:&#xa;  · tool_name, tool_args&#xa;  · result (头部+尾部截断)&#xa;  · timestamp&#xa;facts[]: list[str]&#xa;  （LLM 从证据提炼）&#xa;open_questions[]: list[str]&#xa;stage_complete: bool&#xa;━━━━━━━━━━━&#xa;✏ 写入：Explorer（迭代）&#xa;👁 读取：Executor, Verifier&#xa;🔄 回退入口：Verifier(补充探索)" vertex="1">
          <mxGeometry height="320" width="290" x="680" y="140" as="geometry" />
        </mxCell>
        <mxCell id="exec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="ExecutionArtifact 执行工件&#xa;━━━━━━━━━━━&#xa;actions[]:&#xa;  · action_id, tool_name&#xa;  · status: pending /&#xa;    awaiting_confirmation /&#xa;    completed / rejected / error&#xa;  · confirm_id?, result?&#xa;results[]: list[dict]&#xa;summary: str&#xa;━━━━━━━━━━━&#xa;✏ 写入：Executor&#xa;👁 读取：Verifier, Coordinator&#xa;🔄 回退入口：Verifier(retry)" vertex="1">
          <mxGeometry height="320" width="290" x="990" y="140" as="geometry" />
        </mxCell>
        <mxCell id="flow1" edge="1" parent="1" source="goal" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666" target="plan">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow2" edge="1" parent="1" source="plan" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666" target="obs">
