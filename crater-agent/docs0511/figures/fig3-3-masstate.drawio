        </mxCell>
        <mxCell id="flow3" edge="1" parent="1" source="obs" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666" target="exec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="secB" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;fontColor=#B85450" value="B. 运行时控制 / 证据 / 续接 / 统计" vertex="1">
          <mxGeometry height="20" width="400" x="60" y="480" as="geometry" />
        </mxCell>
        <mxCell id="rt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="运行时控制&#xa;━━━━━━━━━━&#xa;loop_round: int&#xa;no_progress_count: int&#xa;stop_reason: str&#xa;  (completed / max_rounds /&#xa;   no_progress / awaiting_confirm)&#xa;attempted_tool_signatures[]&#xa;  （工具+参数指纹去重）" vertex="1">
          <mxGeometry height="180" width="300" x="60" y="510" as="geometry" />
        </mxCell>
        <mxCell id="audit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="证据 / 审计轨迹&#xa;━━━━━━━━━━&#xa;tool_records[]:&#xa;  · agent_id, agent_role&#xa;  · tool_name, tool_args&#xa;  · tool_call_id&#xa;  · result, latency_ms&#xa;action_history[]:&#xa;  · 写动作完整变迁记录&#xa;  · confirmation_id 关联" vertex="1">
          <mxGeometry height="180" width="300" x="380" y="510" as="geometry" />
        </mxCell>
        <mxCell id="resume" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="确认与恢复&#xa;━━━━━━━━━━&#xa;pending_confirmations[]:&#xa;  · confirm_id, action_payload&#xa;  · risk_level, hint, history&#xa;resume_context:&#xa;  · confirmation_results[]&#xa;workflow（checkpoint v5）:&#xa;  · 整个 MASState 序列化&#xa;  · 由 Backend 持久化" vertex="1">
          <mxGeometry height="180" width="300" x="700" y="510" as="geometry" />
        </mxCell>
        <mxCell id="usage" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" value="使用统计&#xa;━━━━━━━━━━&#xa;usage_summary:&#xa;  · llm_calls, input_tokens&#xa;  · output_tokens, total_tokens&#xa;  · latency_ms&#xa;  · tool_calls (read / write)&#xa;  · evidence_items 数量&#xa;llm_by_role:&#xa;  · 按角色细分 Token 与时延" vertex="1">
          <mxGeometry height="180" width="260" x="1020" y="510" as="geometry" />
        </mxCell>
        <mxCell id="sv" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;fontFamily=Courier New" value="StateView 按角色视图过滤（节省 Token / 角色隔离）&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Planner    👁 Goal · Capabilities                                              ✏ Plan&#xa;Explorer   👁 Goal · Plan · 已有 Observation                          ✏ Observation（追加）&#xa;Executor   👁 Goal · Plan · Observation                                 ✏ Execution&#xa;Verifier   👁 Goal · Plan · Observation · Execution                   ✏ verdict&#xa;Coordinator   👁 全工件 + 运行时控制                                       ✏ stop_reason · next_action" vertex="1">
          <mxGeometry height="160" width="1320" x="40" y="730" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
